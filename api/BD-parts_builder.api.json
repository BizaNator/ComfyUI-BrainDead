    "inputs": {
      "model_name": "Qwen3-VL-8B-Instruct",
      "quantization": "None (FP16)",
      "attention_mode": "auto",
      "preset_prompt": "\ud83d\uddbc\ufe0f Tags",
      "custom_prompt": "Analyze the character image and output a strict list of every visible clothing item, accessory, prop, and worn object. Follow these rules exactly:\n- Output single tag csv for each object,\n- Explicitly separate left and right side items using \"left \" or \"right \" prefixes (e.g., \"left white sleeve\", \"right white sleeve\").\n- Include only the item name and its color/pattern.\n- NEVER combine, group, or describe layering in a single line. (e.g., NEVER write \"white apron over black dress\", \"black dress with white apron\", \"paired boots\", or \"matching gloves\").\n- NEVER use commas, conjunctions, or relational words (over, under, with, and, plus, etc.).\n- If an item is centered or covers both sides equally, list each side seperatly not together, right glove, left glove.\n- If an item has multiple visible colors/patterns, list only the dominant one.\n\nExample output:\nwhite apron\nblack dress\nleft brown leather glove\nright brown leather glove\nleft blue shoe\nright blue shoe\nsilver pendant necklace\nblack belt with silver belt buckel\ndark blue trousers",
      "max_tokens": 1024,
      "keep_model_loaded": true,
      "seed": 1,
      "image": [
        "3",
        0
      ]
    },
    "_meta": {
      "title": "\u2462 QwenVL - Get Clothing Tags"
    }
  },
